{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**",
        "apps/desktop/src-tauri/target/**"
      ]
    },
    "build:vercel": {
      "dependsOn": ["cookycardz-shared#build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "cookycardz-shared#build", "groceryify#build"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "cookycardz-shared#build", "groceryify#build"]
    },
    "lint": { "outputs": [] },
    "test": { "outputs": [] },
    "format": { "outputs": [] }
  }
}
