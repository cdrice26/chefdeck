{
  "name": "cookycardz",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=cookycardz-web...",
    "dev:desktop": "turbo run dev --filter=cookycardz-desktop...",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "cargo": "cd apps/desktop/src-tauri && cargo"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "eslint": "^9",
    "prettier": "^3.7.3",
    "turbo": "^2.9.14",
    "typescript": "^5"
  }
}
